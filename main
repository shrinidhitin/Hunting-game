import tkinter as tk
import random
import numpy as np
import setup_module as sm

width = 10
height = 10

root = tk.Tk()
root.title("Hunting for your village")

inventory_label = tk.Label(root, font=("Arial", 14))
inventory_label.grid(row=0, column=0, columnspan=width)

buttons = []
for row in range(height):
    button_row = []
    for col in range(width):
        button = tk.Button(root, text=" ", font=("Arial", 20), width=2, height=1,)
        button.grid(row=row + 1, column=col)
        button_row.append(button)
    buttons.append(button_row)

root.mainloop()